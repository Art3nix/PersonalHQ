# ─────────────────────────────────────────────
# Flask Security
# ─────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_64_char_hex_value
FLASK_CONFIG=development

# ─────────────────────────────────────────────
# Database (Primary)
# ─────────────────────────────────────────────
# Format:
# postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/app_database

# ─────────────────────────────────────────────
# Database (Other)
# ─────────────────────────────────────────────
DEV_DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/app_dev_database
LOCAL_TEST_DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/app_test_database
DOCKER_TEST_DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/app_test_database

# ─────────────────────────────────────────────
# Postgres
# ─────────────────────────────────────────────
POSTGRES_DB=admin_db
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=super_secure_db_pass

# ─────────────────────────────────────────────
# PgAdmin
# ─────────────────────────────────────────────
PGADMIN_EMAIL=email@example.com
PGADMIN_PASSWORD=super_secure_pgadmin_pass

# ─────────────────────────────────────────────
# Stripe Payments (if used)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────
# Flask-Mail (optional)
# ─────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
